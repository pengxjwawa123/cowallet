# ============================================================================
# cowallet Docker 部署 — 环境变量配置
# ============================================================================
# 复制此文件为 .env 并填入实际值

# ────────────────────────────────────────────────────────────────────────────
# 数据库
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cowallet

# ────────────────────────────────────────────────────────────────────────────
# 区块链 RPC（默认使用 Base Sepolia 测试网）
# ────────────────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia.base.org
RPC_WS_URL=wss://sepolia.base.org

# ────────────────────────────────────────────────────────────────────────────
# 主网 RPC 端点（可选，覆盖默认公共节点）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
ETH_MAINNET_RPC_URL=
# Base Mainnet
BASE_MAINNET_RPC_URL=
# Arbitrum One
ARB_MAINNET_RPC_URL=
# Optimism Mainnet
OP_MAINNET_RPC_URL=
# BSC Mainnet
BSC_MAINNET_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# 测试网 RPC 端点（可选）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Sepolia
ETH_SEPOLIA_RPC_URL=
# Base Sepolia
BASE_SEPOLIA_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# ERC-4337 Bundler 端点（账户抽象）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
BUNDLER_URL_ETH=
# Base Mainnet
BUNDLER_URL_BASE=
# Arbitrum One
BUNDLER_URL_ARB=
# Optimism Mainnet
BUNDLER_URL_OP=
# BSC Mainnet
BUNDLER_URL_BSC=
# Ethereum Sepolia
BUNDLER_URL_ETH_SEPOLIA=
# Base Sepolia
BUNDLER_URL_BASE_SEPOLIA=

# ────────────────────────────────────────────────────────────────────────────
# NATS 消息队列
# ────────────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ────────────────────────────────────────────────────────────────────────────
# Redis 缓存
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ────────────────────────────────────────────────────────────────────────────
# Claude AI API
# ────────────────────────────────────────────────────────────────────────────
# 从 https://console.anthropic.com 获取 API KEY
CLAUDE_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ────────────────────────────────────────────────────────────────────────────
# CORS 跨域配置
# ────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ────────────────────────────────────────────────────────────────────────────
# JWT 认证密钥
# ────────────────────────────────────────────────────────────────────────────
# 用于签发和验证用户登录令牌
# 生成强密钥：openssl rand -base64 32
# ⚠️  生产环境务必使用强密钥（最少 32 字符）
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars

# ────────────────────────────────────────────────────────────────────────────
# 分片加密密钥（32 字节 hex，用于加密 MPC 密钥分片）
# ────────────────────────────────────────────────────────────────────────────
# 生成：openssl rand -hex 32
# ⚠️  生产环境务必使用随机生成的密钥
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ────────────────────────────────────────────────────────────────────────────
# 日志级别
# ────────────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ────────────────────────────────────────────────────────────────────────────
# PostgreSQL 初始化密码（仅 Docker 第一次运行）
# ⚠️  生产环境务必修改为强密码
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=cowallet
