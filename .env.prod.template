# ============================================================================
# cowallet 生产环境配置 — docker-compose.prod.yml 使用
# ============================================================================
# 部署步骤:
#   cp .env.prod.template .env
#   然后填入实际值（标注 ⚠️ 的必须修改）

# ────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
# ⚠️ 生成: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cowallet

# ────────────────────────────────────────────────────────────────────────────
# 安全密钥
# ────────────────────────────────────────────────────────────────────────────
# ⚠️ 生成: openssl rand -base64 32
JWT_SECRET=CHANGE_ME
# ⚠️ 生成: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME

# ────────────────────────────────────────────────────────────────────────────
# AI (DeepSeek)
# ────────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-ba967e4d98f149c0b1d09339c5e6561f
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ────────────────────────────────────────────────────────────────────────────
# GoldRush (Covalent) API — 多链余额查询
# ────────────────────────────────────────────────────────────────────────────
COVALENT_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 0x DEX Aggregator API — 代币兑换 (Swap)
# ────────────────────────────────────────────────────────────────────────────
# 从 https://0x.org/pricing 获取 API KEY（可选，不设则使用免费限流档位）
ZEROX_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# CORS — ⚠️ 改为你的服务器IP或域名
# ────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP:3000

# ────────────────────────────────────────────────────────────────────────────
# RPC 节点（默认免费公共节点，建议替换为付费节点提高稳定性）
# ────────────────────────────────────────────────────────────────────────────
RPC_URL=https://1rpc.io/eth
RPC_WS_URL=wss://1rpc.io/eth
ETH_MAINNET_RPC_URL=
BASE_MAINNET_RPC_URL=
ARB_MAINNET_RPC_URL=
OP_MAINNET_RPC_URL=
BSC_MAINNET_RPC_URL=
POLYGON_MAINNET_RPC_URL=
ETH_SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# Firebase (推送通知，可选)
# ────────────────────────────────────────────────────────────────────────────
FCM_SERVER_KEY=
